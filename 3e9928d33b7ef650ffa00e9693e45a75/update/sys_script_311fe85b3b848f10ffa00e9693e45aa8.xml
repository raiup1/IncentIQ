        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

    var name = current.getValue('name');

    if (!name) {
        return;
    }

    var quota = new GlideRecord('x_ctans_incentnow_quota');
    quota.addQuery('name', name);
    quota.addQuery('sys_id', '!=', current.sys_id); // exclude self
    quota.setLimit(1);
    quota.query();

    if (quota.hasNext()) {

        gs.addErrorMessage(
            "Quota with name '" + name + "' already exists. Please use a unique name."
        );

        current.setAbortAction(true);
    }

})(current, previous);]]></script>
