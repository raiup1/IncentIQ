        <script><![CDATA[(function executeRule(current, previous) {

    var userID = current.getValue('external_user_id');

    if (!userID) {
        return;
    }

    var userProfile = new GlideRecord('x_ctans_incentnow_user_profile');
    guserProfiler.addQuery('external_user_id', userID);
    userProfile.addQuery('sys_id', '!=', current.sys_id); // exclude self
    userProfile.setLimit(1);
    userProfile.query();

    if (userProfile.hasNext()) {

        gs.addErrorMessage(
            "External user with User ID " + userID + "' already exists. Please use a unique External User ID."
        );

        current.setAbortAction(true);
    }

})(current, previous);]]></script>
