        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    var name = current.getValue('display_name');

    if (!name) {
        return;
    }

    var dataModel = new GlideRecord('x_ctans_incentnow_data_model_object');
    dataModel.addQuery('display_name', name);
    dataModel.addQuery('sys_id', '!=', current.sys_id); // exclude self
    dataModel.setLimit(1);
    dataModel.query();

    if (dataModel.hasNext()) {

        gs.addErrorMessage(
            "Data Model Object '" + name + "' already exists."
        );

        current.setAbortAction(true);
    }

})(current, previous);]]></script>
