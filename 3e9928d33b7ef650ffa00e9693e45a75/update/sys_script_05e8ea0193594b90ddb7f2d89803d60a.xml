        <script><![CDATA[(function executeRule(current, previous /*null when async*/) {

	
	var uniqueUserIds = []; 

	try {
		
		var ga = new GlideAggregate('x_ctans_incentnow_data_lake');
		ga.addAggregate('COUNT', 'user_id'); 
		ga.groupBy('user_id'); 
		ga.query(); 

		
		while (ga.next()) {
			var userId = ga.user_id.toString(); 
			if (userId) { 
				uniqueUserIds.push(userId);
			}
		}

		
		//gs.info('Unique User IDs from x_ctans_incentnow_data_lake: ' + JSON.stringify(uniqueUserIds));

		

	} catch (ex) {
		
		//gs.error('Error retrieving unique user IDs from x_ctans_incentnow_data_lake: ' + ex.getMessage());
		
	}	

	g_scratchpad.choices=uniqueUserIds;
	
})(current, previous);]]></script>
