                    <li>Sales User and Manager Configuration</li>
                    <li>Transaction Processing Issues</li>
                    <li>Commission and Payout Calculations</li>
                    <li>Reports and Dashboards</li>
                    <li>General Product Questions</li>
                </ul>
            </div>

            <div class="footer-note">
                © 2026 CtrlAltNow • IncentIQ Support Center
            </div>

        </div>

