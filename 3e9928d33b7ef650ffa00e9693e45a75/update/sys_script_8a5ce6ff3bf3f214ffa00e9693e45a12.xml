        <script><![CDATA[(function executeRule(current, previous /*null when async*/ ) {

    var maxStep = 0;

    var lookupRule = new GlideRecord('x_ctans_incentnow_lookup_rule');
    lookupRule.addQuery('plan', current.plan);
    lookupRule.orderByDesc('step_number');
    lookupRule.setLimit(1);
    lookupRule.query();

    if (lookupRule.next()) {
        maxStep = parseInt(lookupRule.step_number, 10) || 0;
    }

    current.step_number = maxStep + 1;

})(current, previous);]]></script>
