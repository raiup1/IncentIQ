        <name>Generate Statement</name>
        <onclick/>
        <order>100</order>
        <script><![CDATA[(function() {

    var processor = new IncentNowStatementProcessor();
    var result = processor.process(current);

    if (!result.valid) {
        gs.addErrorMessage(result.message);
        action.setRedirectURL(current);
        return;
    }

    //  Show duplicate message
    if (result.isDuplicate) {
        gs.addInfoMessage('Existing statement found. Recalculated and updated.');
    } else {
        gs.addInfoMessage(
            'Incentive statement generated successfully. Total payout: ' +
            result.total
        );
    }

	
	if( (result.valid || result.valid=='true') && result.record.isValidRecord())
    action.setRedirectURL(result.record);

})();]]></script>
