        <script><![CDATA[function onChange(control, oldValue, newValue, isLoading, isTemplate) {

    if (isLoading) {
        return;
    }

    if (!newValue) {
        g_form.clearValue('user_id');
        return;
    }

    var ga = new GlideAjax('IncentNowClientUtils');
    ga.addParam('sysparm_name', 'getUserID');
    ga.addParam('sysparm_user_sys_id', newValue);

    ga.getXMLAnswer(function(response) {

        if (response) {
            g_form.setValue('user_id', response);
        } else {
            g_form.clearValue('user_id');
        }

    });
}]]></script>
